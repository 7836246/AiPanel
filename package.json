{
  "name": "aipanel",
  "version": "0.1.0",
  "private": true,
  "description": "Local AI server operations client — manage Linux servers over SSH from your machine.",
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @aipanel/desktop dev",
    "tauri": "pnpm --filter @aipanel/desktop tauri",
    "tauri:dev": "pnpm --filter @aipanel/desktop tauri dev",
    "build": "pnpm --filter @aipanel/ui build && pnpm --filter @aipanel/desktop build",
    "build:ui": "pnpm --filter @aipanel/ui build",
    "ci:check": "bash scripts/ci-check.sh",
    "release:check": "bash scripts/release-check.sh",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "packageManager": "pnpm@10.28.0"
}
