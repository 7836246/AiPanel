{
  "name": "@aipanel/ui",
  "version": "0.1.0",
  "private": true,
  "description": "AiPanel design system — primitives and ops-domain components.",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./src/styles/tokens.css",
    "./fonts.css": "./fonts.css"
  },
  "files": [
    "dist",
    "fonts",
    "fonts.css",
    "src/styles/tokens.css"
  ],
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:css",
    "build:js": "tsup",
    "build:css": "tailwindcss -i ./src/styles/index.css -o ./dist/styles.css --minify",
    "dev": "concurrently \"tsup --watch\" \"tailwindcss -i ./src/styles/index.css -o ./dist/styles.css --watch\"",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "concurrently": "^9.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5",
    "typescript": "~5.8.3"
  }
}
